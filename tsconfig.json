{
  "compilerOptions": {
    "lib": ["ES2015", "ES2016", "DOM", "ESNext"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2015",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "dist",
    "declarationDir": "dist",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/@types/**/*.d.ts"]
}
