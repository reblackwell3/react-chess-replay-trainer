#!/bin/sh

branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
root=$(git rev-parse --show-toplevel 2>/dev/null || true)
git_dir=$(git rev-parse --git-dir 2>/dev/null || true)
repo=$(basename "$root")

case "$root" in
  */endchess2|*/endchess2/*) workspace=endchess2 ;;
  *) workspace=primary ;;
esac

is_staging_app() {
  case "$repo" in
    endchess-frontend|endchess-backend|endchess-workers|\
    endchess-frontend-2|endchess-backend-2|endchess-workers-2) return 0 ;;
    *) return 1 ;;
  esac
}

is_merge_in_progress() {
  [ -n "$git_dir" ] && [ -f "$git_dir/MERGE_HEAD" ]
}

block_commit() {
  title="$1"
  hint="$2"

  echo "" >&2
  echo "$title" >&2
  echo "$hint" >&2
  echo "" >&2

  if [ "$ENDCHESS_OVERRIDE_PROTECTED_BRANCH" = "1" ]; then
    echo "(ENDCHESS_OVERRIDE_PROTECTED_BRANCH=1 — allowing commit.)" >&2
    return 0
  fi

  if [ ! -t 0 ]; then
    echo "Non-interactive commit blocked." >&2
    return 1
  fi

  printf "Continue anyway? [y/N] " >&2
  read -r reply
  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *)
      echo "Commit aborted." >&2
      return 1
      ;;
  esac
}

if [ "$workspace" = "endchess2" ]; then
  protected=0
  protected_label=""

  if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
    protected=1
    protected_label="$branch"
  elif [ "$branch" = "staging" ]; then
    protected=1
    protected_label="staging"
  elif [ "$branch" = "dev" ]; then
    protected=1
    protected_label="dev"
  fi

  if [ "$protected" = "1" ]; then
    block_commit \
      "BLOCKED: endchess2 workspace — do not commit on '$protected_label'." \
      "Commit on 'dev2'. Merge dev2 into dev when ready (primary workspace handles staging/main)." \
      || exit 1
  fi

  if [ "$branch" != "dev2" ]; then
    echo "" >&2
    echo "WARNING: endchess2 workspace — expected branch 'dev2' (current: '$branch')." >&2
    echo "" >&2
  fi
else
  if [ "$branch" = "dev2" ]; then
    block_commit \
      "BLOCKED: primary endchess workspace — do not commit on 'dev2'." \
      "Commit on 'dev'. Use the endchess2 workspace (/Users/robert/code/endchess2) for dev2 work." \
      || exit 1
  fi

  case "$branch" in
    staging)
      if ! is_merge_in_progress; then
        if is_staging_app; then
          hint="Commit on 'dev', then merge dev → staging (/staging). Only merge commits belong on staging."
        else
          hint="Only merge commits belong on staging (no direct edits)."
        fi
        block_commit \
          "BLOCKED: do not commit directly on 'staging'." \
          "$hint" \
          || exit 1
      fi
      ;;
    main|master)
      if ! is_merge_in_progress; then
        if is_staging_app; then
          hint="Production merges staging → main on GitHub (PR). Only merge commits belong on main."
        else
          hint="Commit on 'dev', then merge dev → main (/staging). Only merge commits belong on main."
        fi
        block_commit \
          "BLOCKED: do not commit directly on '$branch'." \
          "$hint" \
          || exit 1
      fi
      ;;
  esac
fi

exit 0
